# Default: local Codex scene pipeline (no external image API key required)
# API dev server port (default 4174)
# PORT=4174

# Vite dev server port (default 4173) and proxy target for /api, /generated
# VITE_API_PORT=4174

OPENAI_API_KEY=
GEMINI_API_KEY=
MEDIA_BACKEND=codex-scene
OPENAI_MEDIA_BACKEND=
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_REASONING_EFFORT=low

# Gemini / Nano Banana examples
# MEDIA_BACKEND=gemini-image
# MEDIA_BACKEND=nano-banana
# MEDIA_BACKEND=nano-banana-2
# MEDIA_BACKEND=nano-banana-pro
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_ASPECT_RATIO=1:1
GEMINI_IMAGE_SIZE=2K
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI image / Sora examples
# MEDIA_BACKEND=openai-image
# MEDIA_BACKEND=sora
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VIDEO_MODEL=sora-2
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_VIDEO_SECONDS=4
OPENAI_VIDEO_SIZE=720x1280
OPENAI_IMAGE_SIZE=1024x1536
